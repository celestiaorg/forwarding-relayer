# Rust log level for the backend process.
RUST_LOG=info
# Port the backend HTTP server listens on.
PORT=8080
# Filesystem path to the backend SQLite database.
DB_PATH=/var/lib/forwarding-relayer/backend.db
# Port exposed for backend metrics.
BACKEND_METRICS_PORT=9091
# Path to the rate-limit config file (JSON). Leave unset to disable rate limiting.
# See deploy/rate-limit.example.json for the format.
RATE_LIMIT_CONFIG=/etc/forwarding-relayer/rate-limit.json
