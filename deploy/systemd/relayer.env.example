# Rust log level for the relayer process.
RUST_LOG=info
# Celestia gRPC endpoint used for tx client.
CELESTIA_GRPC=http://127.0.0.1:9090
# Base URL for the backend service the relayer consumes requests from.
BACKEND_URL=http://127.0.0.1:8080
# Hex-encoded private key for the relayer wallet.
PRIVATE_KEY_HEX=replace_me
# Polling interval in seconds for relayer (Use blocktime ~6s).
POLL_INTERVAL=6
# Multiplier applied to the estimated IGP fee to provide a safety buffer.
IGP_FEE_BUFFER=1.2
# Port exposed for relayer metrics.
RELAYER_METRICS_PORT=9092
